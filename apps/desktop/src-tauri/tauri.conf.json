{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "2XKO Notes",
  "mainBinaryName": "2XKO Notes",
  "version": "0.5.0",
  "identifier": "com.x2ko.notes",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "2XKO Notes",
        "width": 1280,
        "height": 800,
        "minWidth": 360,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default", "desktop", "mobile"]
    }
  },
  "bundle": {
    "active": true,
    "publisher": "PixelR",
    "copyright": "Copyright © PixelR",
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "licenseFile": "windows/license.txt",
    "resources": [
      "oauth_credentials.json"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "headerImage": "windows/header.bmp",
        "sidebarImage": "windows/sidebar.bmp",
        "installerHooks": "windows/installer-hooks.nsh",
        "languages": ["English"],
        "displayLanguageSelector": false
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVFMTgzQUE2NjQ5NENDMjcKUldRbnpKUmtwam9ZN2h6aWxZOFQvV3QxWTgvSklCY0RqYW1DRGtRc0VROGZrL3RzUDkyV1RkcnkK",
      "endpoints": [
        "https://raw.githubusercontent.com/Piselerre/2XKO-Notes/main/updates-channel/latest-portable.json"
      ],
      "windows": {
        "installMode": "quiet"
      }
    },
    "deep-link": {
      "mobile": [
        {
          "scheme": ["com.x2ko.notes"],
          "host": "oauth",
          "path": ["/callback"]
        }
      ]
    }
  }
}
