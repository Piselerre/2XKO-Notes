{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "2XKO Notes",
  "mainBinaryName": "2XKO Notes",
  "version": "0.4.4",
  "identifier": "com.x2ko.notes",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "2XKO Notes",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "publisher": "PixelR",
    "copyright": "Copyright © PixelR",
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "resources": [
      "oauth_credentials.json"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVFMTgzQUE2NjQ5NENDMjcKUldRbnpKUmtwam9ZN2h6aWxZOFQvV3QxWTgvSklCY0RqYW1DRGtRc0VROGZrL3RzUDkyV1RkcnkK",
      "endpoints": [
        "https://github.com/Piselerre/2XKO-Notes/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
