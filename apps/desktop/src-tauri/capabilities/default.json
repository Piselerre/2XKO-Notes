{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Shared permissions for all platforms",
  "permissions": [
    "core:default",
    "opener:default",
    "opener:allow-default-urls",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "https://*" },
        { "url": "http://*" }
      ]
    },
    "sql:default",
    "process:allow-restart",
    "process:allow-exit"
  ]
}
